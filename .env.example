# =============================================================================
# Environment template — safe to commit (no secrets).
#
# Setup:
#   cp .env.example .env
#   按下方选一种后端填密钥（不要提交 .env）。
#
# Rules:
#   - 真密钥只放在 `.env`（已 gitignore）。
#   - 不要把密钥写进本文件再 push。
# =============================================================================

# -----------------------------------------------------------------------------
# LLM 后端（多选一，建议显式写 LLM_PROVIDER）
#
# - deepseek：官方 API → DEEPSEEK_API_KEY（默认）
# - openai：OpenAI 或任意 OpenAI-Chat-Compatible → OPENAI_API_KEY
# - ark：火山引擎方舟（与 OpenAI Chat Completions 兼容，非 responses 接口）
#
# 自动推断（未写 LLM_PROVIDER 时）：
#   仅 OPENAI_API_KEY → openai；仅 ARK_API_KEY → ark；否则 deepseek。
# 若同时配置了多种密钥，请设置 LLM_PROVIDER=deepseek|openai|ark。
# -----------------------------------------------------------------------------
# LLM_PROVIDER=deepseek
# LLM_PROVIDER=openai
# LLM_PROVIDER=ark

# --- DeepSeek 官方 ---
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-reasoner

# --- OpenAI / 其它 OpenAI 兼容 Chat Completions ---
OPENAI_API_KEY=
# 留空则使用库默认 https://api.openai.com/v1
# OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# --- 火山引擎方舟（DeepSeek V3.2 等）---
# 文档：https://www.volcengine.com/docs/82379/1399008
# 密钥名与官网一致：ARK_API_KEY
#
# 重要：方舟的「普通推理 API Key / Chat Completions」不会让模型自动上网。
# 官网示例里的联网来自 responses.create + tools（如 web_search），与本项目使用的
# Chat Completions 不是同一条能力；当前代码也未接入该 Responses 工具链。
# 论文相关事实来源依赖图内节点：arXiv 拉取、PDF 正文、引用解析等，而不是 LLM 实时搜索。
ARK_API_KEY=
ARK_API_BASE=https://ark.cn-beijing.volces.com/api/v3
# 控制台推理接入点 / 模型 ID，须与方舟一致，例如：
ARK_MODEL=deepseek-v3-2-251201

# =============================================================================
# 数据库（PostgreSQL）
# =============================================================================
# 连接字符串格式：postgresql://user:password@host:port/dbname
# 示例（本地开发）：
# DATABASE_URL=postgresql://researchuser:123@127.0.0.1:5432/researchagent
DATABASE_URL=

# =============================================================================
# Milvus 向量数据库
# =============================================================================
# 启动方式：
#   mkdir -p milvus  (在项目根目录)
#   cd milvus && docker compose up -d
# 连接：
#   MILVUS_HOST=127.0.0.1
#   MILVUS_PORT=19530
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
# Milvus Collection 名称（可选，代码中可动态指定）
# MILVUS_COLLECTION=paper_corpus

# =============================================================================
# SearXNG 搜索服务
# =============================================================================
# SearXNG 实例的基础 URL（JSON API 端点为 {SEARXNG_BASE_URL}/search?q=...&format=json）
# 本地开发： http://127.0.0.1:8080
# 示例（本地 Docker）：
# SEARXNG_BASE_URL=http://127.0.0.1:8080
SEARXNG_BASE_URL=

# =============================================================================
# DeepXiv 论文数据接口
# =============================================================================
# Python 服务进程请显式配置 DEEPXIV_TOKEN，不要依赖 CLI 首次运行时的匿名 token 注册。
# 官方 SDK/API 文档：
#   - https://github.com/DeepXiv/deepxiv_sdk
#   - https://data.rag.ac.cn/api/docs
DEEPXIV_BASE_URL=https://data.rag.ac.cn
DEEPXIV_TOKEN=

# =============================================================================
# 运行示例（方舟 + 本地 SearXNG）
# =============================================================================
# export DEEPSEEK_API_KEY='...'
# export LLM_PROVIDER=deepseek
# export DATABASE_URL='postgresql://researchuser:123@127.0.0.1:5432/researchagent'
# export SEARXNG_BASE_URL='http://127.0.0.1:8080'
# python -m uvicorn src.api.app:app --host 127.0.0.1 --port 8000

# ─── Module 5: Cross-Encoder Rerank ──────────────────────────────────
# 本地 rerank 模型（默认 cross-encoder/ms-marco-MiniLM-L-6-v2）
# 可选（按需替换）：
#   - cross-encoder/ms-marco-MiniLM-L-6-v2  （速度快，英文推荐）
#   - cross-encoder/ms-marco-MiniLM-L-12-v2  （精度更高）
#   - cross-encoder/ms-marco-MultiBERT-L-12  （多语言支持）
# sentence-transformers 会自动从 HuggingFace 下载模型到缓存目录。
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
